# ─── Copy file này thành .env trên VPS rồi điền giá trị thật ───
# (KHÔNG commit .env lên git)

# Database
POSTGRES_DB=voidprotocol
POSTGRES_USER=void_user
POSTGRES_PASSWORD=doi_mat_khau_db_manh_o_day

# JWT secrets — sinh chuỗi ngẫu nhiên dài (mỗi cái >= 32 ký tự)
# Gợi ý tạo: openssl rand -base64 48
ACCESS_TOKEN_SECRET=thay_bang_chuoi_ngau_nhien_dai_1
REFRESH_TOKEN_SECRET=thay_bang_chuoi_ngau_nhien_dai_2

# URL công khai người chơi truy cập
#  - Chạy bằng IP/HTTP:   http://162.4.176.46
#  - Khi có domain+HTTPS:  https://tendomain.com
PUBLIC_URL=http://162.4.176.46

# Cookie bảo mật: để false khi chạy HTTP (IP), đổi true khi đã có HTTPS
COOKIE_SECURE=false

# Cổng HTTP mở ra ngoài (mặc định 80)
HTTP_PORT=80
